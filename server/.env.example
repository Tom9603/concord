# =====================================================================
#  Configuration Pulsar (serveur)
#  Copiez ce fichier en « .env » (dans le meme dossier) puis remplissez.
#  Le fichier .env n'est jamais publie sur GitHub : vos cles restent privees.
#  Lignes commencant par # = commentaires ignores. Redemarrez apres modif.
# =====================================================================

# --- Assistant IA (Rattrapage, Reformuler) --------------------------
# Votre cle Anthropic, a creer sur https://console.anthropic.com (API Keys).
# Tant que cette ligne est vide ou absente, l'IA est desactivee proprement
# (les boutons etoile n'apparaissent pas), le reste de l'app fonctionne.
PULSAR_AI_KEY=

# Nombre d'actions IA gratuites par jour et par utilisateur (defaut : 3).
PULSAR_AI_LIMIT=3

# Modele utilise (defaut : Claude Haiku, le moins cher). A laisser tel quel.
# PULSAR_AI_MODEL=claude-haiku-4-5-20251001

# --- Emails automatiques --------------------------------------------
# Sert au code de confirmation a l'inscription et au « mot de passe oublie ».
# Tant que ces lignes sont absentes : aucun email n'est envoye, les comptes
# sont actives directement, et le « mot de passe oublie » ne fonctionne pas.
#
# Valeurs pour Brevo (gratuit, 300 emails/jour) : creez un compte sur
# brevo.com, puis SMTP & API > SMTP pour obtener identifiant et cle.
# PULSAR_SMTP_HOST=smtp-relay.brevo.com
# PULSAR_SMTP_PORT=587
# PULSAR_SMTP_USER=votre-identifiant-brevo
# PULSAR_SMTP_PASS=votre-cle-smtp-brevo
# PULSAR_MAIL_FROM=Pulsar <no-reply@votre-domaine.com>

# Adresse publique de l'app : sert a construire le lien de reinitialisation
# envoye par email. A renseigner en production.
# PULSAR_PUBLIC_URL=https://votre-domaine.com

# --- Sauvegardes automatiques ---------------------------------------
# Nombre de nuits conservees (defaut : 30). Voir deploy/backup.mjs.
# PULSAR_BACKUP_KEEP=30

# --- Securite -------------------------------------------------------
# Phrase secrete qui signe les connexions. Mettez une longue suite de
# caracteres au hasard. A definir surtout sur le serveur en production.
# JWT_SECRET=changez-moi-par-une-longue-phrase-aleatoire

# --- Reseau ---------------------------------------------------------
# Port d'ecoute du serveur (defaut : 3001).
# PORT=3001
